    "version": "0.2.0",
    "configurations": [

        {
            "type": "java",
            "name": "Current File",
            "request": "launch",
            "mainClass": "${file}"
        },
        {
            "type": "java",
            "name": "Db4allApiApplication",
            "request": "launch",
            "mainClass": "fr.grozeille.db4all.api.Db4allApiApplication",
            "projectName": "db4all-api",
            "cwd": "${workspaceFolder}/api",
            "preLaunchTask": "API: Maven test-compile"
        },
        {
            "type": "node",
            "name": "launch UI",
            "request": "launch",
            "runtimeExecutable": "npm",
            "runtimeArgs": [
                "run",
                "dev"
            ],
            "cwd": "${workspaceFolder}/ui"
        }
    ]
}